# Database Configuration (Optional, defaults to Vizru platform standard)
# MONGO_URL=mongodb://vizru:vizru@receiver-mongo:27017/vizru-live
# MONGO_DB=vizru-live
# MYSQL_DSN=mysql:host=receiver-mysql;dbname=vizru;user=vizru;password=vizru;
# MYSQL_HOST=receiver-mysql
# MYSQL_PORT=3306
# MYSQL_DB=vizru
# MYSQL_USER=vizru
# MYSQL_PASSWORD=vizru

# LLM Configuration
# API key for the LLM service (OpenAI, OpenRouter, Groq, etc.)
LLM_API_KEY=your_llm_api_key_here

# Base URL for OpenAI-compatible endpoints (leave empty for default OpenAI)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_BASE_URL=

# Model to use
LLM_MODEL=gpt-4o-mini
# LLM_TEMPERATURE=0.1

# Other Settings
# CATALOG_TTL_SECONDS=300
