                },
                "sort-order": {
                    "type": "string"
                },
                "action-btns": {
                    "type": "string"
                },
                "values": {
                    "type": "string"
                },
                "field": {
                    "type": "string"
                },
                "Add": {
                    "type": "string"
                },
                "where-clause": {
                    "type": "string"
                },
                "limit": {
                    "type": "string"
                },
                "filter-objects": {
                    "type": "string"
                },
                "variables": {
                    "type": "string"
                },
                "rules-config": {
                    "type": "string"
                },
                "widget_config": {
                    "type": "string"
                },
                "rules-general": {
                    "type": "string"
                },
                "value": {
                    "type": "string"
                },
                "rules-redirect": {
                    "type": "string"
                },
                "rules-static": {
                    "type": "string"
                },
                "key": {
                    "type": "string"
                },
                "operator": {
                    "type": "string"
                },
                "actions": {
                    "type": "string"
                },
                "tabs": {
                    "type": "string"
                },
                "Export": {
                    "type": "string"
                }
