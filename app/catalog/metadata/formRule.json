{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "formRule",
    "type": "object",
    "properties": {
        "componentType": {
            "type": "string",
            "const": "formRule"
        },
        "configuration": {
            "type": "object",
            "properties": {
                "fieldType": {
                    "type": "string"
                },
                "format": {
                    "type": "string"
                },
                "select-fields": {
                    "type": "string"
                },
                "field": {
                    "type": "string"
                },
                "txtId": {
                    "type": "string"
                },
                "formFields": {
                    "type": "string"
                }
            }
        },
        "events": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "execute",
                    "onSuccess",
                    "onFailure"
                ]
            }
        },
        "outputs": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "status",
                    "result_data"
                ]
            }
        }
    },
    "required": [
        "componentType"
    ]
}