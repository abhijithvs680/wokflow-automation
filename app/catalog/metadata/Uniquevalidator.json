{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Uniquevalidator",
    "type": "object",
    "properties": {
        "componentType": {
            "type": "string",
            "const": "Uniquevalidator"
        },
        "configuration": {
            "type": "object",
            "properties": {
                "permissionfinished": {
                    "type": "string"
                },
                "permission": {
                    "type": "string"
                }
            }
        },
        "events": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "execute",
                    "onSuccess",
                    "onFailure"
                ]
            }
        },
        "outputs": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "status",
                    "result_data"
                ]
            }
        }
    },
    "required": [
        "componentType"
    ]
}